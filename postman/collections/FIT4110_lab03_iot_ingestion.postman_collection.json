
{
  "info": {
    "_postman_id": "fit4110-lab03-iot-ingestion",
    "name": "FIT4110 Lab03 IoT Ingestion",
    "description": "Collection for testing Prism mock servers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "IoT Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{iot_base_url}}/health",
          "host": [
            "{{iot_base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('IoT status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
